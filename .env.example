# Mode:
# - signal_only: sends BUY/SELL alerts only (no broker API keys needed)
# - webull: places trades through Webull OpenAPI
BOT_MODE=signal_only

# ===== Webull OpenAPI (required only when BOT_MODE=webull) =====
WEBULL_APP_KEY=
WEBULL_APP_SECRET=
WEBULL_BASE_URL=https://openapi.webull.com
WEBULL_SEC_ACCOUNT_ID=
WEBULL_TICKER_IDS=
WEBULL_REGION_ID=6
WEBULL_EXCHANGE_CODE=US
WEBULL_MARKET=US
WEBULL_TOKEN_EXPIRE_SECONDS=3600

# ===== Market data for signal_only mode =====
MARKET_DATA_SOURCE=yahoo
YAHOO_INTERVAL=1m
YAHOO_RANGE=1d

# Comma-separated symbols to watch
SYMBOLS=SPY,QQQ,AAPL

# Optional: symbols you already hold when bot starts.
# Example: SPY,QQQ
SIGNAL_START_IN_POSITION=

# Poll loop interval (60_000 = 1 minute)
POLL_INTERVAL_MS=60000

# EMA strategy parameters
FAST_EMA=9
SLOW_EMA=21
MAX_POSITION_PCT=0.2

# Risk auto-stop (used in webull trading mode)
STOP_TRADING_EQUITY_FLOOR=
STOP_TRADING_DAILY_LOSS_PCT=
STOP_TRADING_DAILY_PROFIT_PCT=

# Safety switches (used in webull trading mode)
DRY_RUN=true
ENABLE_LIVE_TRADING=false

# ===== Notifications =====
# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# iMessage (optional, macOS only)
IMESSAGE_RECIPIENT=
IMESSAGE_SERVICE=iMessage

# Heartbeat every N cycles
HEARTBEAT_EVERY_CYCLES=15
