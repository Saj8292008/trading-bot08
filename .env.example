# ===== Webull OpenAPI =====
WEBULL_APP_KEY=your_webull_app_key
WEBULL_APP_SECRET=your_webull_app_secret
WEBULL_BASE_URL=https://openapi.webull.com

# Optional: set if account auto-discovery fails
WEBULL_SEC_ACCOUNT_ID=

# Symbol -> ticker_id map (optional). Example: SPY:913256135,QQQ:913324007
# If omitted, bot will call Webull get-ticker endpoint to resolve IDs.
WEBULL_TICKER_IDS=
WEBULL_REGION_ID=6
WEBULL_EXCHANGE_CODE=US
WEBULL_MARKET=US
WEBULL_TOKEN_EXPIRE_SECONDS=3600

# Comma-separated symbols to watch
SYMBOLS=SPY,QQQ,AAPL

# Poll loop interval (60_000 = 1 minute)
POLL_INTERVAL_MS=60000

# Strategy parameters
FAST_EMA=9
SLOW_EMA=21
MAX_POSITION_PCT=0.2

# Safety switches
DRY_RUN=true
ENABLE_LIVE_TRADING=false

# ===== Notifications =====
# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# iMessage (optional, macOS only)
IMESSAGE_RECIPIENT=
IMESSAGE_SERVICE=iMessage

# Heartbeat every N cycles
HEARTBEAT_EVERY_CYCLES=15
